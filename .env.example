# Copy to .env and fill in. .env is gitignored.

# Required for `aidemo voice` (OpenAI TTS) and `aidemo captions` (Whisper) —
# unless a custom base URL below is set, then the key is optional.
OPENAI_API_KEY=sk-...

# Optional: point voice/captions at any OpenAI-compatible server (LocalAI,
# speaches, Kokoro-FastAPI, …). AIDEMO_OPENAI_BASE_URL wins if both are set.
# OPENAI_BASE_URL=http://localhost:8000/v1
# AIDEMO_OPENAI_BASE_URL=http://localhost:8000/v1

# Optional: override the TTS model (useful with local servers, e.g. kokoro).
# AIDEMO_TTS_MODEL=gpt-4o-mini-tts
# Optional: override the STT/transcription model used for caption timing.
# AIDEMO_STT_MODEL=whisper-1

# Optional: dedicated Chrome profile dir handed to Playwright (logged into ChatGPT).
# Defaults to <repo>/chrome-profile. Chrome must NOT be running on this profile during a record.
# AIDEMO_CHROME_PROFILE=/absolute/path/to/chrome-profile

# Optional: capture path — playwright (default) | native | obs.
# native = ffmpeg avfoundation full-screen grab cropped to the viewport (macOS;
# grant your terminal Screen Recording permission). obs = OBS via obs-websocket
# (set the scene to a Display Capture of the primary screen).
# AIDEMO_CAPTURE=native
# AIDEMO_CAPTURE_DEVICE=Capture screen 0
# AIDEMO_OBS_URL=ws://127.0.0.1:4455
# AIDEMO_OBS_PASSWORD=...
