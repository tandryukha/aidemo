# Copy to .env and fill in. .env is gitignored.
#
# Use a key DEDICATED to this engine (a "demo-local" key of its own) — do not
# reuse a key from another project you happen to have lying around. This file
# ALWAYS overrides an OPENAI_API_KEY already exported in your shell (e.g.
# ~/.zshrc, possibly shared across several unrelated repos) — see loadEnv() in
# src/config.ts and `npm run guard-openai-key`. If you invoke `aidemo` from
# inside a DIFFERENT project's directory (cwd), that project's OWN .env (if it
# defines OPENAI_API_KEY) wins over this one — that's the intended way a
# consumer repo supplies its own key next to its own demos/. This file is what
# gets used for this engine's OWN dev/test/example runs, and as the fallback
# for any consumer repo that hasn't set up its own key yet.

# Required for `aidemo voice` (OpenAI TTS) and `aidemo captions` (Whisper) —
# unless a custom base URL below is set, then the key is optional.
OPENAI_API_KEY=sk-...

# Optional: point voice/captions at any OpenAI-compatible server (LocalAI,
# speaches, Kokoro-FastAPI, …). AIDEMO_OPENAI_BASE_URL wins if both are set.
# OPENAI_BASE_URL=http://localhost:8000/v1
# AIDEMO_OPENAI_BASE_URL=http://localhost:8000/v1

# Optional: override the TTS model (useful with local servers, e.g. kokoro).
# AIDEMO_TTS_MODEL=gpt-4o-mini-tts
# Optional: override the STT/transcription model used for caption timing.
# AIDEMO_STT_MODEL=whisper-1

# Optional: dedicated Chrome profile dir handed to Playwright (logged into ChatGPT).
# Defaults to <repo>/chrome-profile. Chrome must NOT be running on this profile during a record.
# AIDEMO_CHROME_PROFILE=/absolute/path/to/chrome-profile

# Optional: capture path — playwright (default) | native | obs.
# native = ffmpeg avfoundation full-screen grab cropped to the viewport (macOS;
# grant your terminal Screen Recording permission). obs = OBS via obs-websocket
# (set the scene to a Display Capture of the primary screen).
# AIDEMO_CAPTURE=native
# AIDEMO_CAPTURE_DEVICE=Capture screen 0
# AIDEMO_OBS_URL=ws://127.0.0.1:4455
# AIDEMO_OBS_PASSWORD=...

# Optional: swap the TTS backend for `aidemo voice` (captions always use the
# OpenAI-compatible endpoint above — except `render` with provider=local and no
# endpoint/key, which derives captions offline from the script). Unset = OpenAI.
# Note: switching provider (or the local dtype) re-voices all scenes; changing
# only the model or default-voice vars reuses cached audio — re-run with
# --force-voice.
# AIDEMO_TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=...
# AIDEMO_ELEVENLABS_MODEL=eleven_multilingual_v2
# Used when the storyboard doesn't pick a voice; explicit voiceIds pass through.
# AIDEMO_ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM

# Optional: in-process TTS — Kokoro-82M on CPU, no server/key. Needs the
# opt-in package first: npm install kokoro-js (~400 MB with onnxruntime).
# First run downloads the model once from huggingface.co; offline after.
# AIDEMO_TTS_PROVIDER=local
# Quantization: q8 (default, ~90 MB) | fp32 (~330 MB, best) | fp16 | q4 | q4f16
# AIDEMO_TTS_MODEL_DTYPE=q8
# Used when the storyboard doesn't pick a voice; explicit voiceIds must be
# Kokoro ids (af_heart, am_adam, …).
# AIDEMO_KOKORO_VOICE=af_heart
# Model cache dir (default: $HF_HOME/transformersjs or ~/.cache/huggingface/transformersjs)
# AIDEMO_TTS_MODEL_CACHE=/absolute/path/to/model-cache
